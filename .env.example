# Environment variables — copy this to .env.local and fill in values

# ─── Stellar Network ───────────────────────────────────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
# Mainnet: https://horizon.stellar.org
# Testnet: https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ─── Deployed Contract IDs (filled after `soroban contract deploy`) ────────────
NEXT_PUBLIC_QUIZ_POOL_CONTRACT_ID=
NEXT_PUBLIC_LEADERBOARD_CONTRACT_ID=

# ─── Passkey Kit / Smart Wallet ───────────────────────────────────────────────
NEXT_PUBLIC_FACTORY_CONTRACT_ID=

# ─── Relayer ──────────────────────────────────────────────────────────────────
# The Stellar account that sponsors fees (fee-bump source)
RELAYER_SPONSOR_SECRET_KEY=
RELAYER_PORT=3001

# ─── Admin / Backend ──────────────────────────────────────────────────────────
ADMIN_STELLAR_SECRET_KEY=

# ─── Launchtube (optional: managed relayer alternative) ───────────────────────
LAUNCHTUBE_API_KEY=
LAUNCHTUBE_URL=https://launchtube.xyz
