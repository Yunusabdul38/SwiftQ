{
  "name": "swiftq",
  "private": true,
  "description": "On-Chain Quiz-to-Earn platform on Stellar — open source monorepo",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "pnpm": {
    "overrides": {}
  }
}
